#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

const int X_PIN  = A0;
const int Y_PIN  = A1;
const int Z_PIN  = A2;
const int ST_PIN = 2;

const byte GREEN_LED  = 3;
const byte YELLOW_LED = 5;
const byte RED_LED    = 6;

const int NUM_SAMPLES = 100;

// ── LCD helper ─────────────────────────────
void lcdShow(const char* l1, const char* l2) {
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print(l1);
  lcd.setCursor(0,1);
  lcd.print(l2);
}

// ── Read raw ADC average ───────────────────
int readADC(int pin) {
  long sum = 0;
  for (int i = 0; i < NUM_SAMPLES; i++) {
    sum += analogRead(pin);
    delay(2);
  }
  return sum / NUM_SAMPLES;
}

// ── Setup ──────────────────────────────────
void setup() {
  pinMode(ST_PIN, OUTPUT);
  digitalWrite(ST_PIN, HIGH);

  pinMode(GREEN_LED, OUTPUT);
  pinMode(YELLOW_LED, OUTPUT);
  pinMode(RED_LED, OUTPUT);

  lcd.init();
  lcd.backlight();

  lcdShow("ADXL335 TEST", "Starting...");
  delay(1500);
}

// ── Main loop ──────────────────────────────
void loop() {

  digitalWrite(YELLOW_LED, HIGH);

  // ── Baseline ──
  lcdShow("Reading", "Baseline");

  int xb = readADC(X_PIN);
  int yb = readADC(Y_PIN);
  int zb = readADC(Z_PIN);

  lcdShow("BASE ADC", "X Y Z");
  delay(1000);

  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("X:");
  lcd.print(xb);
  lcd.print(" Y:");
  lcd.print(yb);

  lcd.setCursor(0,1);
  lcd.print("Z:");
  lcd.print(zb);
  delay(1500);

  // ── Saturation check ──
  bool saturated = (xb > 980 || yb > 980 || zb > 980);

  if (saturated) {
    lcdShow("ERROR", "SATURATED ADC");
    digitalWrite(RED_LED, HIGH);
    digitalWrite(YELLOW_LED, LOW);
    delay(3000);
    return;
  }

  // ── Self-test ON ──
  digitalWrite(ST_PIN, LOW);
  lcdShow("SELF TEST", "Running...");
  delay(300);

  int xs = readADC(X_PIN);
  int ys = readADC(Y_PIN);
  int zs = readADC(Z_PIN);

  // ── Deltas ──
  int xd = xs - xb;
  int yd = ys - yb;
  int zd = zs - zb;

  lcdShow("DELTA X Y", "Z next");
  delay(800);

  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("X:");
  lcd.print(xd);
  lcd.print(" Y:");
  lcd.print(yd);

  lcd.setCursor(0,1);
  lcd.print("Z:");
  lcd.print(zd);
  delay(1500);

  // ── Axis validation ──
  bool xp = (abs(xd) > 200 && abs(xd) < 1200);
  bool yp = (abs(yd) > 200 && abs(yd) < 1200);
  bool zp = (abs(zd) > 200 && abs(zd) < 1200);

  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("X");
  lcd.print(xp ? "P " : "F ");
  lcd.print("Y");
  lcd.print(yp ? "P " : "F ");
  lcd.print("Z");
  lcd.print(zp ? "P" : "F");

  delay(2000);

  // ── Result ──
  digitalWrite(YELLOW_LED, LOW);
  digitalWrite(ST_PIN, HIGH);

  if (xp && yp && zp) {
    digitalWrite(GREEN_LED, HIGH);
    lcdShow("SELF TEST", "PASS");
  } else {
    digitalWrite(RED_LED, HIGH);
    lcdShow("SELF TEST", "FAIL");
  }

  delay(4000);

  digitalWrite(GREEN_LED, LOW);
  digitalWrite(RED_LED, LOW);
}
