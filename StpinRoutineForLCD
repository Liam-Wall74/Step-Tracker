#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

const int X_PIN  = A0;
const int Y_PIN  = A1;
const int Z_PIN  = A2;
const int ST_PIN = 2;

const byte GREEN_LED  = 3;
const byte YELLOW_LED = 5;
const byte RED_LED    = 6;

const float ADC_REF_VOLTAGE = 5.00;
const int   ADC_RESOLUTION  = 1024;
const float MV_PER_COUNT    = (ADC_REF_VOLTAGE / ADC_RESOLUTION) * 1000.0;
const float ST_SCALE        = (3.3/3.0) * (3.3/3.0) * (3.3/3.0);
const float X_EXPECTED      = -325.0 * ST_SCALE;
const float Y_EXPECTED      = +325.0 * ST_SCALE;
const float Z_EXPECTED      = +550.0 * ST_SCALE;
const float TOLERANCE       = 0.30;
const int   NUM_SAMPLES     = 100;

// ── Helper: clear one LCD row ─────────────────────────────────
void clearRow(byte row) {
  lcd.setCursor(0, row);
  lcd.print(F("                "));
}

// ── Helper: display two lines on LCD ─────────────────────────
void lcdShow(const char* line0, const char* line1) {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(line0);
  lcd.setCursor(0, 1);
  lcd.print(line1);
}

// ── Read averaged ADC in mV ───────────────────────────────────
float readMV(int pin) {
  long sum = 0;
  for (int i = 0; i < NUM_SAMPLES; i++) {
    analogRead(pin);
    delayMicroseconds(200);
    sum += analogRead(pin);
    delay(3);
  }
  return ((float)sum / NUM_SAMPLES) * MV_PER_COUNT;
}

// ── Check delta against expected, show result on LCD ─────────
bool checkAndDisplay(float delta, float expected, const char* axis) {
  float lo = expected < 0 ? expected * (1 + TOLERANCE) : expected * (1 - TOLERANCE);
  float hi = expected < 0 ? expected * (1 - TOLERANCE) : expected * (1 + TOLERANCE);
  bool pass = (delta >= lo && delta <= hi);

  // Line 0: axis and result
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(F("Axis "));
  lcd.print(axis);
  lcd.print(pass ? F(" PASS") : F(" FAIL"));

  // Line 1: measured delta
  lcd.setCursor(0, 1);
  lcd.print(F("d="));
  lcd.print(delta, 0);
  lcd.print(F("mV ex="));
  lcd.print(expected, 0);

  delay(2000);
  return pass;
}

// ── Setup ─────────────────────────────────────────────────────
void setup() {
  pinMode(ST_PIN, OUTPUT);
  digitalWrite(ST_PIN, HIGH);   // self-test OFF

  pinMode(GREEN_LED,  OUTPUT);
  pinMode(YELLOW_LED, OUTPUT);
  pinMode(RED_LED,    OUTPUT);

  digitalWrite(GREEN_LED,  LOW);
  digitalWrite(YELLOW_LED, LOW);
  digitalWrite(RED_LED,    LOW);

  lcd.init();
  lcd.backlight();

  lcdShow("ADXL335", "Self-Test Ready");
  delay(2000);
}

// ── Main loop ─────────────────────────────────────────────────
void loop() {

  // ── Step 1 — Read baseline (ST OFF) ──────────────────────
  digitalWrite(ST_PIN, HIGH);   // self-test OFF
  digitalWrite(YELLOW_LED, HIGH);

  lcdShow("Reading", "Baseline...");
  delay(200);

  float xb = readMV(X_PIN);
  float yb = readMV(Y_PIN);
  float zb = readMV(Z_PIN);

  // Show baseline on LCD
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(F("Base X="));
  lcd.print(xb, 0);
  lcd.print(F("mV"));
  lcd.setCursor(0, 1);
  lcd.print(F("Y="));
  lcd.print(yb, 0);
  lcd.print(F(" Z="));
  lcd.print(zb, 0);
  delay(2000);

  // ── Step 2 — Apply self-test (ST ON) ─────────────────────
  digitalWrite(ST_PIN, LOW);    // self-test ON (active-low)

  lcdShow("Applying", "Self-Test...");
  delay(200);

  float xs = readMV(X_PIN);
  float ys = readMV(Y_PIN);
  float zs = readMV(Z_PIN);

  // Show self-test readings on LCD
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(F("ST   X="));
  lcd.print(xs, 0);
  lcd.print(F("mV"));
  lcd.setCursor(0, 1);
  lcd.print(F("Y="));
  lcd.print(ys, 0);
  lcd.print(F(" Z="));
  lcd.print(zs, 0);
  delay(2000);

  // ── Step 3 — Calculate deltas ─────────────────────────────
  float xd = xs - xb;
  float yd = ys - yb;
  float zd = zs - zb;

  // Show deltas on LCD
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(F("Deltas (mV)"));
  lcd.setCursor(0, 1);
  lcd.print(F("X="));
  lcd.print(xd, 0);
  lcd.print(F(" Y="));
  lcd.print(yd, 0);
  lcd.print(F(" Z="));
  lcd.print(zd, 0);
  delay(2000);

  // ── Step 4 — Validate each axis ──────────────────────────
  lcdShow("Validating", "Axes...");
  delay(1000);

  bool xp = checkAndDisplay(xd, X_EXPECTED, "X");
  bool yp = checkAndDisplay(yd, Y_EXPECTED, "Y");
  bool zp = checkAndDisplay(zd, Z_EXPECTED, "Z");

  // ── Step 5 — Overall result ───────────────────────────────
  digitalWrite(YELLOW_LED, LOW);
  digitalWrite(ST_PIN, HIGH);   // self-test OFF

  if (xp && yp && zp) {
    digitalWrite(GREEN_LED, HIGH);
    digitalWrite(RED_LED,   LOW);

    lcdShow("SELF-TEST", "PASS :)");

  } else {
    digitalWrite(RED_LED,   HIGH);
    digitalWrite(GREEN_LED, LOW);

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(F("SELF-TEST FAIL"));
    lcd.setCursor(0, 1);

    // Show which axes failed
    if (!xp) lcd.print(F("X "));
    if (!yp) lcd.print(F("Y "));
    if (!zp) lcd.print(F("Z "));
    lcd.print(F("failed"));
  }

  // Hold result on screen for 5 seconds then repeat
  delay(5000);

  digitalWrite(GREEN_LED, LOW);
  digitalWrite(RED_LED,   LOW);
}
