  Serial.print(F(" V, Raw Y = "));
  Serial.print(raw[1], 2);
  Serial.print(F("  Voltage = "));
  Serial.print(adcToVoltage(raw[1]), 3);
  Serial.print(F(" V, Raw Z = "));
  Serial.print(raw[2], 2);
  Serial.print(F("  Voltage = "));
  Serial.print(adcToVoltage(raw[2]), 3);
  Serial.println(F(" V"));
}

