void displayLiveAcceleration() {
  float raw[3];
  float g[3];

  readXYZAverage(raw, LIVE_SAMPLES);

  for (byte axis = 0; axis < 3; axis++) {
    g[axis] = (raw[axis] - cal.offset[axis]) / cal.scale[axis];
  }

  float magnitude = sqrt(
    g[0] * g[0] +
    g[1] * g[1] +
    g[2] * g[2]
  );

  clearLCDRow(0);
  lcd.setCursor(0, 0);
  lcd.print(F("X:"));
  printSignedLCD(g[0]);
  lcd.print(F(" Y:"));
  printSignedLCD(g[1]);

  clearLCDRow(1);
  lcd.setCursor(0, 1);
  lcd.print(F("Z:"));
  printSignedLCD(g[2]);
  lcd.print(F(" M:"));
  lcd.print(magnitude, 2);

  Serial.print(F("X = "));
  Serial.print(g[0], 2);
  Serial.print(F(" g, Y = "));
  Serial.print(g[1], 2);
  Serial.print(F(" g, Z = "));
  Serial.print(g[2], 2);
  Serial.print(F(" g, Magnitude = "));
  Serial.print(magnitude, 2);
  Serial.println(F(" g"));
}

