//////////////////////////////////////////////////////////////////////
//AMY'S STEP COUNTING FUNCTIONS
/////////////////////////////////////////////////////////////////////
float getAcceleration() {
  // first, we need to read the values from the accelerometer, and calculation the Euclidean Norm Minus One
  float sumX = 0 ;
  float sumY = 0 ;
  float sumZ = 0 ;
  float valueX = 0 ;
  float valueY = 0 ;
  float valueZ = 0 ;
  int samples = 5 ;

  for (int i = 0 ; i < 5 ; i++){
    sumX += (analogRead(X_PIN) - cal.offset[0]) / cal.scale[0] ;
    sumY += (analogRead(Y_PIN) - cal.offset[1]) / cal.scale[1] ;
    sumZ += (analogRead(Z_PIN) - cal. offset[2]) / cal.scale[2] ;
  }

  valueX = sumX/samples ;
  valueY = sumY/samples ;
  valueZ = sumZ/samples ;

  float magnitude = sqrt(valueX * valueX + valueY*valueY + valueZ*valueZ)  ;


  return magnitude ;
}

//////////////////////////////////////////////////////////////////////
//MALINDU'S WALKING PACE IDENTIFICATION FUNCTIONS
/////////////////////////////////////////////////////////////////////

void updateWalkingPace(unsigned long currentStepTime, float stepMagnitude) {
  float stepFrequency = 0.0;

  if (previousStepTime == 0) {
    if (stepMagnitude >= RUN_MAG_MIN) {
      currentPace = RUNNING;
      //runningStepCount++;
    }
    else {
      currentPace = WALKING;
      //walkingStepCount++;
    }
  
    previousStepTime = currentStepTime;
    updatePaceLEDs();
    updatePaceLCD();
    return;
  }

  if (previousStepTime > 0) {
    float stepInterval = (currentStepTime - previousStepTime) / 1000.0;
    stepFrequency = 1.0 / stepInterval;
  }

  if (stepFrequency >= RUN_FREQ_MIN && stepMagnitude >= RUN_MAG_MIN) {
    currentPace = RUNNING;
    //runningStepCount++;
  }
  else if (stepFrequency >= WALK_FREQ_MIN) {
    currentPace = WALKING;
    //walkingStepCount++;
  }

  previousStepTime = currentStepTime;

  updatePaceLEDs();
  updatePaceLCD();
}

void checkStationary() {
  if (millis() - stepTime > STATIONARY_TIMEOUT && currentPace != STATIONARY && resetState != true) {
    currentPace = STATIONARY;
    updatePaceLEDs();
    updatePaceLCD();
  }
}

void updatePaceLEDs() {
  digitalWrite(RED_LED, currentPace == STATIONARY);
  digitalWrite(YELLOW_LED, currentPace == WALKING);
  digitalWrite(GREEN_LED, currentPace == RUNNING);
}

void updatePaceLCD() {
  //lcd.setCursor(0, 0);
  // clear only top right side of row
  lcd.setCursor(11,0) ;
  lcd.print("     ") ;

  lcd.setCursor(11,0) ;

  if (resetState != true) {

    if (currentPace == STATIONARY) {
      lcd.print("Still");
    }
    else if (currentPace == WALKING) {
      lcd.print("Walk ");
    }
    else if (currentPace == RUNNING) {
    lcd.print("Run  ") ;
    }
  } else if (resetState == true) {
    lcd.print("reset") ;
  }
}

