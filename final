// ── Read raw ADC average ───────────────────
int readADC(int pin) {
  long sum = 0;
  for (int i = 0; i < NUM_SAMPLES; i++) {
    sum += analogRead(pin);
    delay(2);
  }
  return sum / NUM_SAMPLES;
}

